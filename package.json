{
	"scripts": {
		"format": "prettier --write .",
		"dev": "vite",
		"safari:convert": "xcrun safari-web-extension-converter dist --project-location ./apps/safari --app-name \"Onshape Plus\" --bundle-identifier com.rileydavidson.onshapeplus",
		"safari:sync": "npm run build && node ./scripts/sync-safari-extension.mjs",
		"safari:open": "open ./apps/safari/Onshape\\ Plus/Onshape\\ Plus.xcodeproj",
		"build": "vite build",
		"build:watch": "vite build --watch",
		"firefox:lint": "web-ext lint --source-dir dist",
		"firefox:run": "web-ext run --source-dir dist",
		"firefox:build": "web-ext build --source-dir dist",
		"firefox:sign": "web-ext sign --source-dir dist"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@types/firefox-webext-browser": "^143.0.0",
		"@types/node": "^25.9.1",
		"@types/react": "^19.2.15",
		"@types/react-dom": "^19.2.3",
		"@types/webextension-polyfill": "^0.12.5",
		"@vitejs/plugin-react": "^6.0.2",
		"typescript": "^6.0.3",
		"vite": "^8.0.14",
		"web-ext": "^10.4.0"
	},
	"dependencies": {
		"@fontsource-variable/geist": "^5.2.9",
		"@tailwindcss/vite": "^4.3.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"lucide-react": "^1.17.0",
		"motion": "^12.40.0",
		"motion-dom": "^12.40.0",
		"radix-ui": "^1.4.3",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"react-draggable": "^4.6.0",
		"shadcn": "^4.10.0",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4.3.0",
		"tw-animate-css": "^1.4.0",
		"webextension-polyfill": "^0.12.0"
	}
