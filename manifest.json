{
  "manifest_version": 3,
  "name": "Onshape Tablet UI",
  "version": "0.1.0",
  "description": "Custom tablet and pen UI improvements for Onshape.",
  "icons": {
    "16": "icons/icon-main.png"
  },
  "content_scripts": [
    {
      "matches": ["https://cad.onshape.com/*"],
      "js": ["src/utils/core.js", "src/utils/floatingNumberPad.js", "src/utils/penSidebar.js"],
      "css": ["src/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage"]
}